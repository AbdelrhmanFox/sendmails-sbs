# Supabase — paste from Project Settings → API (same project for all keys)
# URL: Settings → General → Reference ID → https://<ref>.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Optional if you prefer: SUPABASE_PROJECT_REF=YOUR_PROJECT_REF (URL is built automatically)
# Secret key only (sb_secret_… or legacy service_role). Never commit real values.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here
# Publishable / anon — used by public-config for Realtime (training chat)
SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# JWT signing for dashboard login tokens (any long random string; not the Supabase dashboard password)
JWT_SECRET=your_jwt_secret_here

# One-time seed endpoint /.netlify/functions/seed?key=... (optional)
SEED_SECRET=your_seed_secret_here

# Optional: POST /.netlify/functions/finance-data?resource=n8n-report with header X-N8n-Secret (scheduled finance snapshot)
N8N_FINANCE_WEBHOOK_SECRET=

# Training voice: base URL for auto-generated Jitsi room links (used when the trainer leaves “Voice room link” blank).
# Public meet.jit.si is NOT suitable for embedded or anonymous class voice (Jitsi returns membersOnly / lobby for API embeds and often requires a signed-in moderator).
# For reliable in-dashboard voice, deploy Jitsi Meet yourself and set e.g. JITSI_MEET_BASE=https://meet.yourdomain.com
# JITSI_MEET_BASE=https://meet.jit.si
