    {
      "parameters": {
        "jsCode": "// Merge Subject and Body; normalize email again + _toEmail for SMTP (never spaces in To:).\nfunction cleanEmail(v) {\n  if (v === null || v === undefined) return '';\n  return String(v).replace(/[\\u200B-\\u200D\\uFEFF]/g, '').replace(/\\u00A0/g, ' ').trim();\n}\nfunction cleanEmailList(v) {\n  return String(v || '')\n    .split(/[;,]/)\n    .map(cleanEmail)\n    .filter(Boolean)\n    .join(', ');\n}\nfunction normalizeKey(key) {\n  return String(key || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '');\n}\nfunction escapeRegExp(str) {\n  return String(str).replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\nfunction replacePlaceholderCI(text, key, value) {\n  const pattern = new RegExp('\\\\{\\\\{\\\\s*' + escapeRegExp(key) + '\\\\s*\\\\}\\\\}', 'gi');\n  return String(text).replace(pattern, String(value));\n}\nconst webhook = $('Webhook').first().json;\nconst body = webhook.body || webhook;\nlet subject = String(body.subject ?? webhook.subject ?? '');\nlet html = String(body.bodyHtml ?? webhook.bodyHtml ?? '');\nconst row = { ...$input.item.json };\nif ('Email' in row) row.Email = cleanEmail(row.Email);\nif ('email' in row) row.email = cleanEmail(row.email);\nconst _toEmail = cleanEmail(row.Email || row.email);\nconst _ccEmail = cleanEmailList(body.cc ?? webhook.cc ?? '');\nconst rowKeyByNormalized = {};\nfor (const key of Object.keys(row)) {\n  const nk = normalizeKey(key);\n  if (nk && !rowKeyByNormalized[nk]) rowKeyByNormalized[nk] = key;\n}\nfunction getRowValueByAliases(aliases) {\n  for (const alias of aliases) {\n    const key = rowKeyByNormalized[normalizeKey(alias)];\n    if (!key) continue;\n    const value = row[key];\n    if (value !== null && value !== undefined && String(value).trim() !== '') return value;\n  }\n  return null;\n}\nconst courseValue = getRowValueByAliases(['course', 'course_name', 'courseid', 'coures']);\nif (courseValue !== null) {\n  for (const alias of ['course', 'course_name', 'coures']) {\n    subject = replacePlaceholderCI(subject, alias, courseValue);\n    html = replacePlaceholderCI(html, alias, courseValue);\n  }\n}\nfor (const [k, v] of Object.entries(row)) {\n  if (v === null || v === undefined) continue;\n  subject = replacePlaceholderCI(subject, k, v);\n  html = replacePlaceholderCI(html, k, v);\n}\nreturn { json: { ...row, _subject: subject, _html: html, _toEmail, _ccEmail } };"
      },
