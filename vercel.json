{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "echo Build complete",
  "outputDirectory": "dashboard",
  "rewrites": [
    {
      "source": "/.netlify/functions/:name",
      "destination": "/api/:name"
    }
  ],
  "functions": {
    "api/[name].js": {
      "maxDuration": 30
    }
  }
}
